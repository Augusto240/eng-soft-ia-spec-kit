{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PolicyStatus",
  "type": "object",
  "required": ["status", "label", "definition"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["legalized", "medical_only", "decriminalized", "illegal", "restricted"]
    },
    "label": { "type": "string" },
    "definition": { "type": "string" }
  },
  "additionalProperties": false
}
