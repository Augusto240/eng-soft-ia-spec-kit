{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TimelineEvent",
  "type": "object",
  "required": ["id", "year", "title", "summary", "status", "region"],
  "properties": {
    "id": { "type": "string" },
    "year": { "type": "number" },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["legalized", "decriminalized", "medical", "prohibited", "unknown"]
    },
    "region": { "type": "string" }
  },
  "additionalProperties": false
}
