{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Highlight",
  "type": "object",
  "required": ["id", "title", "summary", "region", "status", "date", "sources"],
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "region": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "legalized",
        "medical_only",
        "decriminalized",
        "illegal",
        "restricted",
        "unknown"
      ]
    },
    "date": { "type": "string" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["government", "international", "regulator", "research", "other"]
          }
        },
        "additionalProperties": false
      }
    },
    "confidenceLabel": {
      "type": "string",
      "enum": [
        "Verified",
        "Source-linked",
        "Needs Verification",
        "Partial Information",
        "Region-specific"
      ]
    }
  },
  "additionalProperties": false
}
